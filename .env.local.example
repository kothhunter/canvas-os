# Supabase — get these from your Supabase project dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — used only for cron jobs (server-side only, never expose to client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Cron secret — generate a random string, e.g.: openssl rand -hex 32
# Used to authenticate Vercel Cron calls to /api/sync/cron
CRON_SECRET=your-random-cron-secret-here
